<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="InicioSesion" parallel="false">
    <parameter name="browser" value="firefox"/>
    <parameter name="headless" value="true"/>
    <parameter name="baseUrl" value="https://practice.automationtesting.in/my-account/"/>
    <parameter name="validUser" value="<VALID_USER>"/>
    <parameter name="validPass" value="<VALID_PASS>"/>
    <parameter name="invalidUser" value="correo_incorrecto@example.com"/>
    <parameter name="invalidPass" value="password_incorrecto"/>
    <parameter name="autoRegister" value="false"/>

    <test name="CasosLoginReto5">
        <classes>
            <class name="tests.IniciarSesion_CredencialesCorrectas"/>
            <class name="tests.IniciarSesion_CorreoIncorrecto"/>
        </classes>
    </test>
</suite>
